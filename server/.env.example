PORT=5000
# MongoDB Atlas — one line, no spaces around =, no quotes unless your password has spaces
# If login fails with "bad auth", add &authSource=admin (Atlas DB users usually authenticate against admin)
# URL-encode special characters in USER or PASSWORD: @ : / # ? $ [ ] etc.
MONGODB_URI=mongodb+srv://USER:<db_password>@CLUSTER.mongodb.net/quickpost?retryWrites=true&w=majority&appName=your-app&authSource=admin
# Local fallback
# MONGODB_URI=mongodb://127.0.0.1:27017/quickpost
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# Comma-separated allowed origins for CORS (no trailing slash)
CORS_ORIGIN=http://localhost:5173,https://yourdomain.com

# Password reset links use this as the site base (recommended on Railway/Netlify)
# PUBLIC_APP_URL=https://your-site.netlify.app

# Optional: send reset emails via https://resend.com (npm package "resend" — set key or forgot-password logs link only)
# RESEND_API_KEY=re_xxxx
# RESEND_FROM_EMAIL=QuickPost <onboarding@resend.dev>

# Solo dev only: API JSON will include resetUrl (do NOT enable on public production)
# RETURN_PASSWORD_RESET_LINK=true
