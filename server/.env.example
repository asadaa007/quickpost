PORT=5000
# MongoDB Atlas (replace <db_password>, add /quickpost before ?)
MONGODB_URI=mongodb+srv://USER:<db_password>@CLUSTER.mongodb.net/quickpost?retryWrites=true&w=majority&appName=your-app
# Local fallback
# MONGODB_URI=mongodb://127.0.0.1:27017/quickpost
JWT_SECRET=your-super-secret-jwt-key-change-in-production
# Comma-separated allowed origins for CORS (no trailing slash)
CORS_ORIGIN=http://localhost:5173,https://yourdomain.com
