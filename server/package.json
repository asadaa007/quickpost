{
  "name": "quickpost-server",
  "version": "1.0.0",
  "description": "QuickPost API — Express + MongoDB",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node --dns-result-order=ipv4first server.js",
    "dev": "node --dns-result-order=ipv4first --watch server.js",
    "test:db": "node --dns-result-order=ipv4first test-connection.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^6.21.0",
    "mongoose": "^8.7.0",
    "resend": "^4.8.0"
  }
}
